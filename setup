#!/usr/bin/env bash
# PaperSkills setup — register skills with Claude Code / Codex / Gemini CLI
set -e

PAPERSKILLS_DIR="$(cd "$(dirname "$0")" && pwd)"
INSTALL_SKILLS_DIR="$(dirname "$PAPERSKILLS_DIR")"
SKILLS_BASENAME="$(basename "$INSTALL_SKILLS_DIR")"

# ─── Detect install context ────────────────────────────────────
# If installed inside .claude/skills/ or .agents/skills/, auto-link sub-skills
# Otherwise, print manual instructions

SKILL_DIRS=(abstract cite-verify citation-network journal-match lit-search peer-review research-gap topic-framing)

link_skill_dirs() {
  local paperskills_dir="$1"
  local skills_dir="$2"
  local linked=()
  for skill_name in "${SKILL_DIRS[@]}"; do
    local skill_dir="$paperskills_dir/$skill_name"
    if [ -f "$skill_dir/SKILL.md" ]; then
      local target="$skills_dir/$skill_name"
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        ln -snf "paperskills/$skill_name" "$target"
        linked+=("$skill_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

if [ "$SKILLS_BASENAME" = "skills" ]; then
  # Installed inside a skills directory — auto-link
  link_skill_dirs "$PAPERSKILLS_DIR" "$INSTALL_SKILLS_DIR"
  echo "paperskills ready."
  echo "  root: $PAPERSKILLS_DIR"
  echo ""
  echo "Available skills:"
  echo "  /paperskills    — smart router (dispatches to sub-skills)"
  for skill_name in "${SKILL_DIRS[@]}"; do
    echo "  /$skill_name"
  done
else
  echo "paperskills is not installed inside a skills directory."
  echo ""
  echo "To install for Claude Code:"
  echo "  git clone https://github.com/cocoafun/paperskills.git ~/.claude/skills/paperskills"
  echo "  cd ~/.claude/skills/paperskills && ./setup"
  echo ""
  echo "To install for Codex:"
  echo "  git clone https://github.com/cocoafun/paperskills.git ~/.agents/skills/paperskills"
  echo "  cd ~/.agents/skills/paperskills && ./setup"
  echo ""
  echo "To install for a single project:"
  echo "  mkdir -p .claude/skills  # or .agents/skills"
  echo "  ln -s /path/to/paperskills .claude/skills/paperskills"
  echo "  cd .claude/skills/paperskills && ./setup"
fi
