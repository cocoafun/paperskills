#!/usr/bin/env bash
# PaperSkills legacy setup helper for clone-based installs.
set -e

PAPERSKILLS_DIR="$(cd "$(dirname "$0")" && pwd)"
INSTALL_SKILLS_DIR="$(dirname "$PAPERSKILLS_DIR")"
SKILLS_BASENAME="$(basename "$INSTALL_SKILLS_DIR")"

# ─── Detect install context ────────────────────────────────────
# If installed inside a skills directory, auto-link sub-skills.
# Otherwise, point users to the registry installer.

CORE_COLLECTION="paperskills-core"
SKILL_DIRS=(abstract cite-verify citation-network journal-match lit-search paper-tracker peer-review research-gap topic-framing)
LINK_DIRS=(shared "${SKILL_DIRS[@]}")

link_skill_dirs() {
  local paperskills_dir="$1"
  local skills_dir="$2"
  local linked=()
  for entry_name in "${LINK_DIRS[@]}"; do
    if [ "$entry_name" = "shared" ]; then
      local entry_dir="$paperskills_dir/shared"
    else
      local entry_dir="$paperskills_dir/skills/$CORE_COLLECTION/$entry_name"
    fi
    if [ -d "$entry_dir" ] && { [ "$entry_name" = "shared" ] || [ -f "$entry_dir/SKILL.md" ]; }; then
      local target="$skills_dir/$entry_name"
      if [ -L "$target" ] || [ ! -e "$target" ]; then
        if [ "$entry_name" = "shared" ]; then
          ln -snf "paperskills/shared" "$target"
        else
          ln -snf "paperskills/skills/$CORE_COLLECTION/$entry_name" "$target"
        fi
        linked+=("$entry_name")
      fi
    fi
  done
  if [ ${#linked[@]} -gt 0 ]; then
    echo "  linked skills: ${linked[*]}"
  fi
}

if [ "$SKILLS_BASENAME" = "skills" ]; then
  # Installed inside a skills directory — auto-link
  link_skill_dirs "$PAPERSKILLS_DIR" "$INSTALL_SKILLS_DIR"
  echo "paperskills ready."
  echo "  root: $PAPERSKILLS_DIR"
  echo ""
  echo "Available skills:"
  echo "  /paperskills    — smart router (dispatches to sub-skills)"
  for skill_name in "${SKILL_DIRS[@]}"; do
    echo "  /$skill_name"
  done
else
  echo "paperskills is not installed inside a skills directory."
  echo ""
  echo "Prefer the PaperSkills registry installer:"
  echo ""
  echo "  curl -sSL https://paperskills.com/scripts/paperskills-install.sh | bash -s -- \\"
  echo "    --tool codex \\"
  echo "    --skills paperskills-core \\"
  echo "    --registry https://paperskills.com/api/registry"
  echo ""
  echo "Replace --tool codex with claude, opencode, or cursor as needed."
fi
