{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paperskills.dev/schemas/design-brief.schema.json",
  "title": "Research Design Brief",
  "type": "object",
  "additionalProperties": false,
  "required": ["topic", "target_contribution", "research_questions"],
  "properties": {
    "topic": { "type": "string" },
    "target_contribution": { "type": "string" },
    "theoretical_lens": { "type": "string" },
    "research_questions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "hypotheses": {
      "type": "array",
      "items": { "type": "string" }
    },
    "method_candidates": {
      "type": "array",
      "items": { "type": "string" }
    },
    "data_sources": {
      "type": "array",
      "items": { "type": "string" }
    },
    "constraints": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
