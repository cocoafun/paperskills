{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paperskills.dev/schemas/draft-brief.schema.json",
  "title": "Paper Draft Brief",
  "type": "object",
  "additionalProperties": false,
  "required": ["paper_goal", "language", "sections"],
  "properties": {
    "paper_goal": { "type": "string" },
    "audience": { "type": "string" },
    "venue_target": { "type": "string" },
    "language": { "type": "string" },
    "citation_style": { "type": "string" },
    "sections": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "goal"],
        "properties": {
          "name": { "type": "string" },
          "goal": { "type": "string" },
          "claims": {
            "type": "array",
            "items": { "type": "string" }
          },
          "evidence": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
