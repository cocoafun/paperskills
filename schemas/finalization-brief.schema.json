{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paperskills.dev/schemas/finalization-brief.schema.json",
  "title": "Manuscript Finalization Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "paper_title",
    "target_artifact",
    "completion_standard",
    "manuscript_type",
    "language",
    "required_sections"
  ],
  "properties": {
    "paper_title": { "type": "string" },
    "target_artifact": { "type": "string" },
    "completion_standard": { "type": "string" },
    "manuscript_type": { "type": "string" },
    "study_completion_status": { "type": "string" },
    "language": { "type": "string" },
    "citation_style": { "type": "string" },
    "evidence_status": { "type": "string" },
    "draft_status": { "type": "string" },
    "required_sections": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "unresolved_gaps": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
