{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paperskills.dev/schemas/tracking-brief.schema.json",
  "title": "Tracking Brief",
  "type": "object",
  "additionalProperties": false,
  "required": ["window", "filters", "limit", "include_preprints"],
  "properties": {
    "window": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "from": { "type": "string", "format": "date" },
        "to": { "type": "string", "format": "date" },
        "days": { "type": "integer", "minimum": 1 }
      }
    },
    "filters": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "journals": { "type": "array", "items": { "type": "string" } },
        "authors": { "type": "array", "items": { "type": "string" } },
        "topics": { "type": "array", "items": { "type": "string" } },
        "domain": { "type": "string" }
      }
    },
    "limit": { "type": "integer", "minimum": 1 },
    "include_preprints": { "type": "boolean" },
    "registry_path": { "type": "string" }
  }
}
