{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paperskills.dev/schemas/reviewer-brief.schema.json",
  "title": "Reviewer Brief",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "language", "review_depth", "input_completeness", "content"],
  "properties": {
    "title": { "type": "string" },
    "domain": { "type": "string" },
    "venue_target": { "type": "string" },
    "paper_type": { "type": "string" },
    "language": { "type": "string" },
    "review_style": { "type": "string" },
    "review_depth": { "type": "string", "enum": ["quick", "standard", "deep"] },
    "input_completeness": { "type": "string", "enum": ["full-paper", "partial-paper", "abstract-only"] },
    "focus_areas": {
      "type": "array",
      "items": { "type": "string" }
    },
    "content": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": { "type": "string" }
    },
    "claims": {
      "type": "array",
      "items": { "type": "string" }
    },
    "known_constraints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "target_output": { "type": "string" }
  }
}
